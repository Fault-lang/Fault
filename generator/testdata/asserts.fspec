spec asserts;

def fsample = flow{
    target: new ssample,
    fn: func{
        target.value -> target.value/2;
    },
};

def ssample = stock{
    value: 40,
};

assert ssample.value == 40;
assume fsample.target.value > 2;

run init{test = new fsample;} {
    test.fn;
    test.fn;
    test.fn;
    test.fn;
}