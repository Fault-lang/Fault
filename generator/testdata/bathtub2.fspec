spec bathtub2;

def faucet = flow{
    water: new tub,
    in: func{
        water.level <- 10;
    },
    out: func{
        water.level -> 20;
    },
};

def tub = stock{
    level: 5, // out of 100%
};

run init{drawn = new faucet;
    } {
    drawn.in | drawn.out;
    drawn.in | drawn.out;
    drawn.in | drawn.out;
}