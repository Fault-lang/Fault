spec multicond;

def s = stock{
    cond: 1,
    value: 10,
};

def f = flow{
    base: new s,
    change: func{
        if base.cond < 4 {
            if base.cond > 0 {
                base.value <- 20;
            }
            base.cond <- 1;
        }
    },
};

run init{t = new f;} {
    t.change;
    t.change;
    t.change;
};
