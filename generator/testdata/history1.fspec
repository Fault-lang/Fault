spec history1;

def v = stock{
    value: 1,
};

def counter = flow{
    place: new v,
    step: func{
        if place.value > 0 {
            place.value <- place.value[now-1];
        } else {
            place.value = 1;
        }
    }
};

run init{c = new counter;} {
    c.step;
    c.step;
    c.step;
    c.step;
}
