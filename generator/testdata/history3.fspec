spec history3;

def v = stock{
    value: 0,
};

def seq = flow{
    place: new v,
    step: func{
        if place.value == 0 {
            place.value = 1;
        } else {
            place.value <- place.value[now-3];
        }
    }
};

run init{s = new seq;} {
    s.step;
    s.step;
    s.step;
    s.step;
    s.step;
    s.step;
    s.step;
}
