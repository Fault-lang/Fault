spec history4;

def v = stock{
    value: 0,
    A: true,
    B: true,
};

def seq = flow{
    place: new v,
    step: func{
        if place.A { 
            if place.B { 
                place.value <- place.value[now-1];
            }
        }
    }
};

for 5 init{s = new seq;} run{
    s.step;
}
