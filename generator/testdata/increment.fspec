spec increment;

def v = stock{
    value: 0,
};

def fib = flow{
    place: new v,
    step: func{
        if place.value == 0 {
              place.value = 1;
        }else{
              place.value <- place.value[now-1];
        }
    }
};

run init{f = new fib;} {
    f.step;
    f.step;
    f.step;
    f.step;
    f.step;
}