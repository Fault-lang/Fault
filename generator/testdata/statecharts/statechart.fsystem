system statechart;

import simple "../simpleA.fspec";

global fl = new simple.fl;

component drain = states{
    initial: func{
        if !simple.active {
            advance(this.open);
        }
    },
    open: func{
        if fl.vault.value < 0 {
            advance(this.close);
        }
    },
    close: func{
        stay();
    },
};

run {
    drain.initial;
    if !drain.close{
        fl.fn;
    }
    if !drain.close{
        fl.fn;
    }
}