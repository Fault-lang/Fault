system trigger;

import simple "../simpleA.fspec";

global fl = new simple.fl;

component x = states{
    foo: func{
        fl.fn;
    },
    bar: func{
        if simple.active {
            fl.fn;
        }
    },
    bash: func{
        if simple.active {
            advance(this.foo);
        }else{
            fl.fn;
        }
    },
};

start {
    x: foo,
};