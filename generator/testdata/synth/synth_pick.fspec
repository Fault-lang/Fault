spec synth_pick;

// Two candidate functions: increment and decrement.
// Solver must pick increment to satisfy value > 10.

def counter = stock{
    value: 10,
};

def ctrl = flow{
    c: new counter,
    increment: func{
        c.value <- 1;
    },
    decrement: func{
        c.value -> 1;
    },
};

assume counter.value > 10 eventually;

run init{ inst = new ctrl; } {
    __;
};
